# ─────────────────────────────────────
# PLXYGROUND FRONTEND — Environment Template
# Copy to .env and fill in real values.
# All variables MUST be prefixed EXPO_PUBLIC_ to be
# accessible in the Expo bundle.
# ─────────────────────────────────────

# Backend API base URL
# Local dev:   http://localhost:3001/api
# Production:  https://your-backend.railway.app/api
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001/api

# App environment label shown in-app
EXPO_PUBLIC_ENV=development

# Optional: Sentry DSN for error tracking
# EXPO_PUBLIC_SENTRY_DSN=
