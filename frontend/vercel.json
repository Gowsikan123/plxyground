{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "ignoreCommand": "git diff HEAD~1 --name-only | grep -q '^frontend/' || exit 0",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
