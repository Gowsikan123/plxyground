# EditorConfig — https://editorconfig.org
# Ensures consistent coding style across all editors & IDEs

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.json]
indent_size = 2

[Makefile]
indent_style = tab

[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

[*.bat]
end_of_line = crlf

[*.ps1]
end_of_line = crlf
indent_size = 4
