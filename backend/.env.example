# Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# PostgreSQL connection string
# Local example:  postgresql://postgres:password@localhost:5432/plxyground
# Supabase example: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/plxyground

# JWT signing secret — must be at least 32 characters
JWT_SECRET=change-me-to-a-long-random-secret-string

# Port the backend listens on (optional, defaults to 3011)
PORT=3011

# Environment: development | test | production
NODE_ENV=development
