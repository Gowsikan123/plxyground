# ─────────────────────────────────────
# PLXYGROUND BACKEND — Environment Template
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────

# PostgreSQL connection string
# Local:      postgresql://user:password@localhost:5432/plxyground
# Railway:    copy from Railway dashboard
DATABASE_URL=postgresql://user:password@localhost:5432/plxyground

# JWT secret for creator/business tokens — min 32 characters
JWT_SECRET=change-me-to-a-random-32-plus-char-string

# Separate JWT secret for admin tokens — min 32 characters
ADMIN_JWT_SECRET=change-me-to-a-different-random-32-plus-char-string

# Token expiry (e.g. 7d, 24h, 1h)
JWT_EXPIRY=7d

# Server port
PORT=3001

# Environment: development | test | production
NODE_ENV=development

# Auto-run DB seed on first startup? true | false
AUTO_SEED=true

# CORS — comma-separated allowed origins
# Example: http://localhost:8081,https://plxyground.app
CORS_ALLOWED_ORIGINS=http://localhost:8081

# Optional: Cloudinary for media uploads
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
